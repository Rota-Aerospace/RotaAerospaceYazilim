<?xml version="1.0" encoding="UTF-8"?>
<sdf version="1.9">
  <world name="default">
    <physics type="ode">
      <max_step_size>0.004</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>250</real_time_update_rate>
    </physics>
    <gravity>0 0 -9.8</gravity>
    <magnetic_field>6e-06 2.3e-05 -4.2e-05</magnetic_field>
    <atmosphere type="adiabatic"/>
    <scene>
      <ambient>0.8 0.8 0.8 1</ambient>
      <background>0.8 0.8 0.8 1</background>
      <shadows>false</shadows>
    </scene>

    <!-- ===== PX4 SITL İÇİN ZORUNLU PLUGİNLER ===== -->
    <plugin filename="gz-sim-physics-system"
      name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-sensors-system"
      name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin filename="gz-sim-scene-broadcaster-system"
      name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-contact-system"
      name="gz::sim::systems::Contact"/>
    <plugin filename="gz-sim-imu-system"
      name="gz::sim::systems::Imu"/>
    <plugin filename="gz-sim-air-pressure-system"
      name="gz::sim::systems::AirPressure"/>
    <plugin filename="gz-sim-magnetometer-system"
      name="gz::sim::systems::Magnetometer"/>
    <plugin filename="gz-sim-navsat-system"
      name="gz::sim::systems::NavSat"/>
    <plugin filename="gz-sim-user-commands-system"
      name="gz::sim::systems::UserCommands"/>

    <!-- ===== ZEMİN 1000x1000 ===== -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane><normal>0 0 1</normal><size>1 1</size></plane>
          </geometry>
          <surface><friction><ode/></friction><bounce/><contact/></surface>
        </collision>
        <visual name="visual">
          <geometry>
            <plane><normal>0 0 1</normal><size>1000 1000</size></plane>
          </geometry>
          <material>
            <ambient>0.4 0.65 0.2 1</ambient>
            <diffuse>0.4 0.65 0.2 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- ===== SİYAH ASFALT PİST 500x30 ===== -->
    <model name="pist">
      <static>true</static>
      <pose>0 0 0.02 0 0 0</pose>
      <link name="pist_link">
        <visual name="pist_visual">
          <geometry><box><size>500 30 0.05</size></box></geometry>
          <material>
            <ambient>0.08 0.08 0.08 1</ambient>
            <diffuse>0.1 0.1 0.1 1</diffuse>
            <specular>0.2 0.2 0.2 1</specular>
          </material>
        </visual>
        <collision name="col">
          <geometry><box><size>500 30 0.05</size></box></geometry>
        </collision>
      </link>
    </model>

    <!-- ===== SARI KENAR ÇİZGİLERİ ===== -->
    <model name="edge_north"><static>true</static><pose>0 14.7 0.06 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><box><size>500 0.5 0.01</size></box></geometry>
        <material><ambient>1 0.85 0 1</ambient><diffuse>1 0.85 0 1</diffuse><specular>0.3 0.3 0 1</specular></material>
      </visual></link></model>

    <model name="edge_south"><static>true</static><pose>0 -14.7 0.06 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><box><size>500 0.5 0.01</size></box></geometry>
        <material><ambient>1 0.85 0 1</ambient><diffuse>1 0.85 0 1</diffuse><specular>0.3 0.3 0 1</specular></material>
      </visual></link></model>

    <!-- ===== SARI KESİK ORTA ÇİZGİLER (40m aralık) ===== -->
    <model name="yc_1"><static>true</static><pose>-240 0 0.06 0 0 0</pose><link name="l"><visual name="v"><geometry><box><size>15 0.4 0.01</size></box></geometry><material><ambient>1 0.85 0 1</ambient><diffuse>1 0.85 0 1</diffuse><specular>0.3 0.3 0 1</specular></material></visual></link></model>
