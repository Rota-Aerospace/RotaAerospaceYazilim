    <model name="yc_7"><static>true</static><pose>0 0 0.06 0 0 0</pose><link name="l"><visual name="v"><geometry><box><size>15 0.4 0.01</size></box></geometry><material><ambient>1 0.85 0 1</ambient><diffuse>1 0.85 0 1</diffuse><specular>0.3 0.3 0 1</specular></material></visual></link></model>
    <model name="yc_8"><static>true</static><pose>40 0 0.06 0 0 0</pose><link name="l"><visual name="v"><geometry><box><size>15 0.4 0.01</size></box></geometry><material><ambient>1 0.85 0 1</ambient><diffuse>1 0.85 0 1</diffuse><specular>0.3 0.3 0 1</specular></material></visual></link></model>
    <model name="yc_9"><static>true</static><pose>80 0 0.06 0 0 0</pose><link name="l"><visual name="v"><geometry><box><size>15 0.4 0.01</size></box></geometry><material><ambient>1 0.85 0 1</ambient><diffuse>1 0.85 0 1</diffuse><specular>0.3 0.3 0 1</specular></material></visual></link></model>
    <model name="yc_10"><static>true</static><pose>120 0 0.06 0 0 0</pose><link name="l"><visual name="v"><geometry><box><size>15 0.4 0.01</size></box></geometry><material><ambient>1 0.85 0 1</ambient><diffuse>1 0.85 0 1</diffuse><specular>0.3 0.3 0 1</specular></material></visual></link></model>
    <model name="yc_11"><static>true</static><pose>160 0 0.06 0 0 0</pose><link name="l"><visual name="v"><geometry><box><size>15 0.4 0.01</size></box></geometry><material><ambient>1 0.85 0 1</ambient><diffuse>1 0.85 0 1</diffuse><specular>0.3 0.3 0 1</specular></material></visual></link></model>
    <model name="yc_12"><static>true</static><pose>200 0 0.06 0 0 0</pose><link name="l"><visual name="v"><geometry><box><size>15 0.4 0.01</size></box></geometry><material><ambient>1 0.85 0 1</ambient><diffuse>1 0.85 0 1</diffuse><specular>0.3 0.3 0 1</specular></material></visual></link></model>
    <model name="yc_13"><static>true</static><pose>240 0 0.06 0 0 0</pose><link name="l"><visual name="v"><geometry><box><size>15 0.4 0.01</size></box></geometry><material><ambient>1 0.85 0 1</ambient><diffuse>1 0.85 0 1</diffuse><specular>0.3 0.3 0 1</specular></material></visual></link></model>

